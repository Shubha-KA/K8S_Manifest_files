apiVersion: apps/v1
kind: Deployment
metadata:
  name: ey-cart-deploy 
  namespace: shubha-ns
  labels:
    app: cart-app
spec: #It defines the behaviour of the ReplicaSet
  replicas: 3
  selector: #It defines how the ReplicaSet finds which Pods to manage
    matchLabels:
      app: cart-web
  template: #It contains pod definition
    metadata:
      labels:
        app: cart-web
    spec: # It contains container definition
      containers: 
        - name: ey-cart-container
          image: muralisocial123/ey-cart:v1.1.0
          ports:
            - containerPort: 3000

  